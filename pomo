# =============================================================================
# resolve_app_base_dir() - Central storage resolver with full fallback
# =============================================================================
#
# SINGLE SOURCE OF TRUTH for all ${APP_NAME} storage decisions.
# Handles missing /dev/shm, missing $HOME, and ensures we always have
# a writable location or die() with clear message.
#
# Priority for volatile mode:
#   1. /dev/shm          (fastest, RAM)
#   2. /tmp              (standard fallback, almost always available)
#   3. /tmp/${APP_NAME}_${USERNAME}  (safe per-user subdir when $HOME is missing)
#
# For persistent mode: always tries XDG_CACHE_HOME → ~/.cache → /tmp/${APP_NAME}_${USERNAME}
#
# !!! DO NOT MODIFY OR DUPLICATE THIS LOGIC !!!
# All ${APP_NAME} functions must use this helper (via get_app_file or directly)
# to keep behavior 100% consistent.
# =============================================================================

resolve_app_base_dir() {
    local requested_mode="$1"
    local actual_mode="$requested_mode"
    local base_dir

    # === Volatile mode fallback chain ===
    if [ "$requested_mode" = "volatile" ]; then
        if [ -d "$VOLATILE_DIR" ] && [ -w "$VOLATILE_DIR" ]; then
            base_dir="$VOLATILE_DIR"
        elif [ -d "/tmp" ] && [ -w "/tmp" ]; then
            actual_mode="fallback"
            base_dir="/tmp"
            if [ "${QUIET}" -eq 0 ] && [ "${JSON}" -eq 0 ]; then
                warn "Volatile storage (/dev/shm) not available. Falling back to /tmp."
            fi
        else
            # Last resort: create a per-user subdirectory under /tmp
            base_dir="/tmp/${APP_NAME}_${USERNAME}"
            if ! mkdir -p "$base_dir" 2>/dev/null || [ ! -w "$base_dir" ]; then
                die "No writable temporary storage available (/dev/shm, /tmp). ${APP_NAME} cannot start."
            fi
            actual_mode="fallback"
            if [ "${QUIET}" -eq 0 ] && [ "${JSON}" -eq 0 ]; then
                warn "Volatile storage unavailable. Using fallback directory: $base_dir"
            fi
        fi
    else
        # === Persistent mode ===
        if [ -n "${HOME:-}" ] && [ -d "${HOME}" ] && [ -w "${HOME}" ]; then
            base_dir="${PERSISTENT_DIR}"
            mkdir -p "$base_dir" 2>/dev/null || true
        else
            # No usable $HOME → fallback to /tmp per-user directory
            base_dir="/tmp/${APP_NAME}_${USERNAME}_persistent"
            if ! mkdir -p "$base_dir" 2>/dev/null || [ ! -w "$base_dir" ]; then
                die "No writable location for persistent storage (no usable \$HOME and cannot write to /tmp). ${APP_NAME} cannot continue."
            fi
            if [ "${QUIET}" -eq 0 ] && [ "${JSON}" -eq 0 ]; then
                warn "No usable \$HOME detected. Persistent timers will use fallback directory: $base_dir"
            fi
        fi
    fi

    echo "$base_dir"
}

# =============================================================================
# get_app_file() - Return full path to pomo file
# =============================================================================
#
# Uses the central resolve_app_base_dir() helper to guarantee consistent
# fallback behavior and warning across the entire script.
#
# Uses the same storage resolver logic (volatile + persistent with fallbacks).
# - volatile  → /dev/shm (fast, lost on reboot)
# - persistent → ~/.cache/pomo (survives reboot)
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# It must remain a thin wrapper around the central resolver.
# =============================================================================

get_app_file() {
    local name="$1"
    local requested_mode="$2"
    local base_dir

    base_dir=$(resolve_app_base_dir "$requested_mode")   # Reuse existing resolver

    # App filename format guarantees per-user isolation
    echo "${base_dir}/${APP_NAME}_${USERNAME}_${name}"
}

# =============================================================================
# sanitize_name() - Prevent dangerous characters in timer names
# =============================================================================
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# Security / robustness measure for filename safety.
# =============================================================================

sanitize_name() {
    case "$NAME" in
        *[/\\:*?"<>|'\''"\`\$]*|*..*|*\$\(*|*${IFS}*)
            if [ "${JSON}" -eq 1 ]; then
                output_json_error "Invalid timer name: contains forbidden characters" "invalid_name"
            else
                error "Invalid timer name '${NAME}' (contains forbidden characters)"
            fi
            exit 1
            ;;
        "")
            NAME="default"
            ;;
    esac
}

# =============================================================================
# parse_duration() - Convert human duration string to seconds
# =============================================================================
#
# Supports formats:
#   25m      → 1500
#   90s      → 90
#   1h       → 3600
#   1h30m    → 5400
#   2h15m45s → 8115
#   45       → 45 (treated as seconds)
#
# Returns the number of seconds (integer) or 0 on error.
#
# !!! DO NOT SIMPLIFY THIS FUNCTION !!!
# It must remain robust against malformed input.
# =============================================================================

parse_duration() {
    local input="$1"
    local total=0
    local num

    # Empty input
    [ -z "$input" ] && echo 0 && return 0

    # If it's just a number, treat as seconds
    if printf '%s' "$input" | grep -qE '^[0-9]+$'; then
        echo "$input"
        return 0
    fi

    # Parse h/m/s components
    while [ -n "$input" ]; do
        num=$(printf '%s' "$input" | grep -oE '^[0-9]+')
        [ -z "$num" ] && echo 0 && return 0

        # Remove the number we just parsed
        input=$(printf '%s' "$input" | sed "s/^$num//")

        case "$input" in
            h* ) total=$((total + num * 3600)); input="${input#h}" ;;
            m* ) total=$((total + num * 60));   input="${input#m}" ;;
            s* ) total=$((total + num));        input="${input#s}" ;;
            *  ) echo 0; return 0 ;;   # Invalid character
        esac
    done

    echo "$total"
}

# =============================================================================
# increment_pomo_stats() - Update daily completed pomodoros and total minutes
# =============================================================================

increment_pomo_stats() {
    local minutes="$1"
    local stats_file
    stats_file=$(get_stats_file)

    mkdir -p "${stats_file%/*}" 2>/dev/null || true

    local count=0 total_min=0
    if [ -f "$stats_file" ]; then
        read -r count total_min < "$stats_file" 2>/dev/null || true
    fi

    count=$((count + 1))
    total_min=$((total_min + minutes))

    printf "%s %s\n" "$count" "$total_min" > "$stats_file" 2>/dev/null || true
}

# =============================================================================
# pomo_start() - Start a new Pomodoro timer
# =============================================================================
#
# Supports:
#   pomo start                  → 25 min work (default)
#   pomo start 40               → 40 min work
#   pomo start 50 --break 10    → 50 min work + 10 min break
#   pomo start --persist        → persistent storage
#   pomo start focus 30 --break 7 --persist
#
# Stores in file: start_time target_time phase work_dur break_dur
#   phase: "work" or "break"
#
# Uses atomic file creation to prevent race conditions.
# Automatically respects --persist flag and central storage resolver.
#
# !!! DO NOT SIMPLIFY THIS LOGIC !!!
# Proper "already running" detection and state format are critical.
# =============================================================================

pomo_start() {
    local duration_str="$1"
    local work_minutes="${DEFAULT_WORK_MIN:-25}"
    local break_minutes="${DEFAULT_BREAK_MIN:-5}"
    local mode="volatile"
    [ "$PERSIST" -eq 1 ] && mode="persistent"

    local APP_FILE
    APP_FILE=$(get_app_file "$NAME" "$mode")

    # Parse custom durations if provided
    if [ -n "$CUSTOM_WORK" ]; then
        work_minutes="$CUSTOM_WORK"
    fi
    if [ -n "$CUSTOM_BREAK" ]; then
        break_minutes="$CUSTOM_BREAK"
    fi

    # If first argument looks like a duration, use it as work time
    if [ -n "$duration_str" ] && printf '%s' "$duration_str" | grep -qE '^[0-9]+$'; then
        work_minutes="$duration_str"
    fi

    # Convert to seconds
    local work_seconds break_seconds
    work_seconds=$((work_minutes * 60))
    break_seconds=$((break_minutes * 60))

    if [ "$work_seconds" -le 0 ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Invalid work duration" "invalid_duration"
        else
            error "Invalid work duration."
        fi
        exit 1
    fi

    # Check if already running
    if [ -f "$APP_FILE" ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json "error" "Pomodoro '${NAME}' is already running." \
                "code" "already_running" \
                "name" "$NAME" \
                "mode" "$mode"
        else
            warn "Pomodoro '${NAME}' is already running."
        fi
        exit 1
    fi

    # Calculate times
    local start_time target_time
    start_time=$(date +%s)
    target_time=$((start_time + work_seconds))

    # Save state: start_time target_time phase work_dur break_dur
    if ! printf "%s %s %s %s %s\n" \
        "$start_time" "$target_time" "work" "$work_seconds" "$break_seconds" \
        > "$APP_FILE" 2>/dev/null; then
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Cannot create pomodoro file" "io_error"
        else
            error "Cannot create pomodoro file."
        fi
        exit 1
    fi

    # Success output
    if [ "${JSON}" -eq 1 ]; then
        output_json "success" "Pomodoro '${NAME}' started." \
            "name" "$NAME" \
            "mode" "$mode" \
            "phase" "work" \
            "duration" "$work_seconds" \
            "remaining" "$work_seconds" \
            "work_minutes" "$work_minutes" \
            "break_minutes" "$break_minutes"
    else
        local icon color
        icon=$(get_icon "work")
        color=$(get_phase_color)

        printf "${color}%s Work phase started${NC} — %d minutes\n" "$icon" "$work_minutes"
        [ "$PERSIST" -eq 1 ] && printf "  (persistent mode)\n"
        printf "\n"
    fi
}

# =============================================================================
# pomo_stop() - Stop current pomodoro and optionally count it as completed
# =============================================================================
#
# Behavior:
#   - Without --force: counts as completed pomodoro (if in work phase)
#   - With --force or "kill": discards without counting
#   - Works for both work and break phases
#   - Updates daily stats when a work session is completed
#
# Uses central get_app_file() for storage.
# Fully supports --json and --quiet modes.
#
# !!! DO NOT SIMPLIFY THE STATS LOGIC !!!
# Accurate daily counting is a core feature.
# =============================================================================

pomo_stop() {
    local name="${1:-default}"
    local mode="${2:-volatile}"
    local APP_FILE
    APP_FILE=$(get_app_file "$name" "$mode")

    if [ ! -f "$APP_FILE" ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "No pomodoro '${name}' running." "no_pomodoro"
        else
            warn "No pomodoro '${name}' running."
        fi
        exit 1
    fi

    # Read state
    local start_time target_time phase work_dur break_dur
    if ! read -r start_time target_time phase work_dur break_dur < "$APP_FILE" 2>/dev/null; then
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Corrupted pomodoro file" "corrupted_data"
        else
            error "Corrupted pomodoro file."
        fi
        rm -f "$APP_FILE" 2>/dev/null || true
        exit 1
    fi

    local current_time elapsed_minutes
    current_time=$(date +%s 2>/dev/null) || current_time=0
    elapsed_minutes=$(( (current_time - start_time) / 60 ))

    # Remove the file
    rm -f "$APP_FILE" 2>/dev/null || true

    # If it's a work phase and not forced kill → count as completed
    if [ "$phase" = "work" ] && [ "${FORCE}" -eq 0 ] && [ "$COMMAND" != "kill" ]; then
        increment_pomo_stats "$elapsed_minutes"

        if [ "${JSON}" -eq 1 ]; then
            output_json "success" "Work pomodoro completed." \
                "name" "$name" \
                "mode" "$mode" \
                "minutes" "$elapsed_minutes" \
                "counted" "true"
        else
            success "Work session completed — ${elapsed_minutes} minutes counted."
        fi
    else
        # Discarded (break phase or --force / kill)
        if [ "${JSON}" -eq 1 ]; then
            output_json "success" "Pomodoro discarded." \
                "name" "$name" \
                "mode" "$mode" \
                "counted" "false"
        else
            if [ "${FORCE}" -eq 1 ] || [ "$COMMAND" = "kill" ]; then
                warn "Pomodoro discarded (not counted)."
            else
                success "Pomodoro stopped."
            fi
        fi
    fi
}

# =============================================================================
# pomo_watch() - Live watch mode with continuous status refresh
# =============================================================================
#
# Continuously refreshes the pomodoro status every second.
# Shows themed icon, phase, remaining time, and progress bar.
# Supports both volatile and persistent modes.
# Exits cleanly when the pomodoro finishes or on Ctrl+C.
#
# Uses show_pomo_status() as the single source of truth for rendering.
# Prints terminal bell (\a) when a phase naturally ends.
#
# !!! DO NOT SIMPLIFY THE LOOP !!!
# Clear + redraw + sleep pattern is important for smooth UX.
# =============================================================================

pomo_watch() {
    local name="${1:-default}"
    local mode="${2:-volatile}"

    if [ "${JSON}" -eq 1 ] || [ "${QUIET}" -eq 1 ]; then
        warn "Watch mode cannot be used with --json or --quiet."
        return 1
    fi

    printf "Watching pomodoro '%s' — Press Ctrl+C to exit\n\n" "$name"

    while true; do
        clear 2>/dev/null || printf "\033[2J\033[H"

        show_pomo_status "$name" "$mode"
        local ret=$?

        if [ "$ret" -eq 2 ]; then
            # Full session (work + break) completed
            printf "\n${GREEN}%s Full pomodoro session finished!${NC}\n" "$(get_icon "done")"
            sleep 1.5
            break
        fi

        sleep 1
    done
}
    
# =============================================================================
# pomo_skip() - Skip current phase (work → break or break → work)
# =============================================================================
#
# Behavior:
#   - If in "work" phase: finishes it and immediately starts break phase
#   - If in "break" phase: finishes it and immediately starts next work phase
#   - Counts the work session as completed when skipping from work
#   - Prints terminal bell when switching phases
#
# Uses the same state file format as pomo_start().
# Fully supports JSON and quiet modes.
#
# !!! DO NOT SIMPLIFY PHASE SWITCHING LOGIC !!!
# Accurate counting of completed pomodoros when skipping work is important.
# =============================================================================

pomo_skip() {
    local name="${1:-default}"
    local mode="${2:-volatile}"
    local APP_FILE
    APP_FILE=$(get_app_file "$name" "$mode")

    if [ ! -f "$APP_FILE" ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "No pomodoro '${name}' running." "no_pomodoro"
        else
            warn "No pomodoro '${name}' running to skip."
        fi
        exit 1
    fi

    # Read current state
    local start_time target_time phase work_dur break_dur
    if ! read -r start_time target_time phase work_dur break_dur < "$APP_FILE" 2>/dev/null; then
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Corrupted pomodoro file" "corrupted_data"
        else
            error "Corrupted pomodoro file."
        fi
        rm -f "$APP_FILE" 2>/dev/null || true
        exit 1
    fi

    local current_time
    current_time=$(date +%s 2>/dev/null) || current_time=0

    # If we are in work phase and skipping → count it as completed
    if [ "$phase" = "work" ]; then
        local elapsed_minutes=$(( (current_time - start_time) / 60 ))
        increment_pomo_stats "$elapsed_minutes"
    fi

    # Remove current phase
    rm -f "$APP_FILE" 2>/dev/null || true

    # Determine next phase and start it
    local next_phase next_duration next_icon
    if [ "$phase" = "work" ]; then
        next_phase="break"
        next_duration="$break_dur"
        next_icon=$(get_icon "break")
    else
        next_phase="work"
        next_duration="$work_dur"
        next_icon=$(get_icon "work")
    fi

    # Start next phase immediately
    local new_start new_target
    new_start=$(date +%s)
    new_target=$((new_start + next_duration))

    if ! printf "%s %s %s %s %s\n" \
        "$new_start" "$new_target" "$next_phase" "$work_dur" "$break_dur" \
        > "$APP_FILE" 2>/dev/null; then
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Failed to start next phase" "io_error"
        else
            error "Failed to start next phase."
        fi
        exit 1
    fi

    # Success output
    if [ "${JSON}" -eq 1 ]; then
        output_json "success" "Skipped to ${next_phase} phase." \
            "name" "$name" \
            "mode" "$mode" \
            "new_phase" "$next_phase"
    else
        local color
        color=$(get_phase_color)

        printf '\a'  # terminal bell on phase switch

        printf "${color}%s Switched to %s phase${NC}\n" "$next_icon" "$next_phase"
        if [ "$next_phase" = "break" ]; then
            printf "Enjoy your break!\n"
        else
            printf "Back to focus!\n"
        fi
        printf "\n"
    fi
}

# =============================================================================
# pomo_theme() - Handle all theme-related subcommands
# =============================================================================
#
# Supports:
#   pomo theme list
#   pomo theme set <name>
#   pomo theme next
#   pomo theme prev
#
# Saves current theme to persistent storage.
# Fully respects --quiet and --json modes.
#
# !!! DO NOT SIMPLIFY THEME CYCLING LOGIC !!!
# Consistent cycling (default → energetic → minimal → default) is important for UX.
# =============================================================================

pomo_theme() {
    local subcommand="$1"
    local arg="$2"

    # If no subcommand, show help
    if [ -z "$subcommand" ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Theme subcommand required (list, set, next, prev)" "missing_subcommand"
        else
            warn "Theme subcommand required. Use: pomo theme list|set|next|prev"
        fi
        return 1
    fi

    case "$subcommand" in
        list)
            if [ "${JSON}" -eq 1 ]; then
                output_json "list" "" \
                    "type" "themes" \
                    "current" "$THEME" \
                    "available" "default energetic minimal"
            else
                if [ "${QUIET}" -eq 0 ]; then
                    msg "Available themes:"
                    printf "  default    - Classic tomato style %s\n" "$(get_icon "work")"
                    printf "  energetic  - Dynamic & motivating %s\n" "$(get_icon "work")"
                    printf "  minimal    - Zen & clean %s\n" "$(get_icon "work")"
                    empty_line
                    printf "Current theme: ${GREEN}%s${NC}\n" "$THEME"
                fi
            fi
            ;;

        set)
            if [ -z "$arg" ]; then
                if [ "${JSON}" -eq 1 ]; then
                    output_json_error "Theme name required" "missing_argument"
                else
                    error "Theme name required. Example: pomo theme set energetic"
                fi
                return 1
            fi

            case "$arg" in
                default|energetic|minimal)
                    local theme_file="${PERSISTENT_DIR}/theme"
                    mkdir -p "${PERSISTENT_DIR}" 2>/dev/null || true
                    echo "$arg" > "$theme_file" 2>/dev/null || true

                    # Update in-memory theme
                    THEME="$arg"

                    if [ "${JSON}" -eq 1 ]; then
                        output_json "success" "Theme changed successfully." \
                            "theme" "$arg"
                    else
                        if [ "${QUIET}" -eq 0 ]; then
                            local icon
                            icon=$(get_icon "work")
                            success "Theme changed to: $arg $icon"
                        fi
                    fi
                    ;;

                *)
                    if [ "${JSON}" -eq 1 ]; then
                        output_json_error "Invalid theme '$arg'. Available: default, energetic, minimal" "invalid_theme"
                    else
                        error "Invalid theme '$arg'. Available: default, energetic, minimal"
                    fi
                    return 1
                    ;;
            esac
            ;;

        next)
            local new_theme
            case "$THEME" in
                default)   new_theme="energetic" ;;
                energetic) new_theme="minimal"   ;;
                minimal)   new_theme="default"   ;;
                *)         new_theme="energetic" ;;
            esac

            local theme_file="${PERSISTENT_DIR}/theme"
            mkdir -p "${PERSISTENT_DIR}" 2>/dev/null || true
            echo "$new_theme" > "$theme_file" 2>/dev/null || true
            THEME="$new_theme"

            if [ "${JSON}" -eq 1 ]; then
                output_json "success" "Switched to next theme." "theme" "$new_theme"
            else
                if [ "${QUIET}" -eq 0 ]; then
                    local icon
                    icon=$(get_icon "work")
                    success "Switched to: $new_theme $icon"
                fi
            fi
            ;;

        prev)
            local new_theme
            case "$THEME" in
                default)   new_theme="minimal"   ;;
                energetic) new_theme="default"   ;;
                minimal)   new_theme="energetic" ;;
                *)         new_theme="minimal"   ;;
            esac

            local theme_file="${PERSISTENT_DIR}/theme"
            mkdir -p "${PERSISTENT_DIR}" 2>/dev/null || true
            echo "$new_theme" > "$theme_file" 2>/dev/null || true
            THEME="$new_theme"

            if [ "${JSON}" -eq 1 ]; then
                output_json "success" "Switched to previous theme." "theme" "$new_theme"
            else
                if [ "${QUIET}" -eq 0 ]; then
                    local icon
                    icon=$(get_icon "work")
                    success "Switched to: $new_theme $icon"
                fi
            fi
            ;;

        *)
            if [ "${JSON}" -eq 1 ]; then
                output_json_error "Unknown theme subcommand '$subcommand'" "invalid_subcommand"
            else
                error "Unknown theme subcommand '$subcommand'. Use: list, set, next, prev"
            fi
            return 1
            ;;
    esac
}

# =============================================================================
# pomo_stats() - Show daily pomodoro statistics
# =============================================================================
#
# Displays number of completed pomodoros and total minutes today.
# Uses persistent storage with fallback via resolve_app_base_dir().
# Fully supports --json and --quiet modes.
#
# !!! DO NOT SIMPLIFY STATS FILE HANDLING !!!
# Graceful fallback when no stats file exists is important.
# =============================================================================

pomo_stats() {
    local stats_file
    stats_file=$(get_stats_file)

    local count=0 total_min=0

    if [ -f "$stats_file" ]; then
        read -r count total_min < "$stats_file" 2>/dev/null || true
    fi

    if [ "${JSON}" -eq 1 ]; then
        output_json "stats" "" \
            "date" "$(get_today)" \
            "completed" "$count" \
            "total_minutes" "$total_min"
    else
        if [ "${QUIET}" -eq 0 ]; then
            if [ "$count" -eq 0 ]; then
                msg "No pomodoros completed today."
            else
                local icon
                icon=$(get_icon "stats")
                success "${icon} Today: ${count} pomodoros • ${total_min} minutes"
            fi
        fi
    fi
}

# =============================================================================
# pomo_list() - List all running pomodoros for the current user
# =============================================================================
#
# Shows all active pomodoros (both volatile and persistent).
# Displays:
#   - Themed icon
#   - Name
#   - Current phase (Work / Break)
#   - Remaining time in MM:SS
#
# Automatically cleans up expired pomodoros.
# Fully supports --json and --quiet modes.
#
# Uses central resolve_app_base_dir() for consistent storage handling.
# =============================================================================

pomo_list() {
    local requested_mode="$1"   # "volatile", "persistent", or both if not specified
    local base_dir timers_json count=0
    local show_all=false

    # If no mode specified or "both", we show both volatile and persistent
    if [ -z "$requested_mode" ] || [ "$requested_mode" = "both" ]; then
        show_all=true
    fi

    if [ "${JSON}" -eq 1 ]; then
        timers_json="["
        local first=true
    else
        if [ "${QUIET}" -eq 0 ]; then
            msg "Running pomodoros:"
        fi
    fi

    # Function to scan one storage directory
    scan_directory() {
        local dir="$1"
        local mode_name="$2"

        [ -d "$dir" ] || return

        for file in "${dir}"/pomo_"${USERNAME}"_*; do
            [ -f "$file" ] || continue

            local name="${file##*pomo_${USERNAME}_}"
            local start_time target_time phase work_dur break_dur
            if ! read -r start_time target_time phase work_dur break_dur < "$file" 2>/dev/null; then
                rm -f "$file" 2>/dev/null || true
                continue
            fi

            local current_time remaining minutes seconds
            current_time=$(date +%s 2>/dev/null) || continue
            remaining=$((target_time - current_time))

            # Auto-cleanup expired
            if [ "$remaining" -le 0 ]; then
                rm -f "$file" 2>/dev/null || true
                continue
            fi

            minutes=$((remaining / 60))
            seconds=$((remaining % 60))

            local phase_name="Work"
            [ "$phase" = "break" ] && phase_name="Break"

            local icon
            icon=$(get_icon "$phase")

            count=$((count + 1))

            if [ "${JSON}" -eq 1 ]; then
                if [ "$first" = false ]; then
                    timers_json="${timers_json},"
                fi
                timers_json="${timers_json}{\"name\":\"${name}\",\"mode\":\"${mode_name}\",\"phase\":\"${phase}\",\"phase_name\":\"${phase_name}\",\"remaining\":${remaining},\"minutes\":${minutes},\"seconds\":${seconds}}"
                first=false
            else
                if [ "${QUIET}" -eq 0 ]; then
                    printf "  %s %-12s %-6s %02d:%02d remaining\n" \
                        "$icon" "$name" "(${phase_name})" "$minutes" "$seconds"
                fi
            fi
        done
    }

    # Scan directories
    if [ "$show_all" = true ] || [ "$requested_mode" = "volatile" ]; then
        local volatile_dir
        volatile_dir=$(resolve_app_base_dir "volatile")
        scan_directory "$volatile_dir" "volatile"
    fi

    if [ "$show_all" = true ] || [ "$requested_mode" = "persistent" ]; then
        local persistent_dir
        persistent_dir=$(resolve_app_base_dir "persistent")
        scan_directory "$persistent_dir" "persistent"
    fi

    # Final output
    if [ "${JSON}" -eq 1 ]; then
        timers_json="${timers_json}]"
        output_json "list" "" \
            "mode" "${requested_mode:-both}" \
            "count" "$count" \
            "timers" "$timers_json"
    else
        if [ "${QUIET}" -eq 0 ]; then
            if [ "$count" -eq 0 ]; then
                msg "  No running pomodoros found."
            fi
            empty_line
        fi
    fi
}

# =============================================================================
# THEME AND VISUAL HELPERS
# =============================================================================
#
# These functions provide the beautiful themed output for pomo:
#   - Icons per phase and theme
#   - Progress bar characters (filled / empty) that differ by theme
#   - Phase-specific colors
#
# All functions are designed to be safe, POSIX-compatible, and work
# even if theme file is missing or corrupted.
#
# !!! DO NOT SIMPLIFY OR REMOVE THEME FALLBACKS !!!
# The default theme must always work as a safe fallback.
# =============================================================================

# ----------------------------- Theme Loading ---------------------------------
# Loads the current theme from persistent storage.
# Falls back to "default" if file is missing, empty, or invalid.
load_theme() {
    : "${THEME:=default}"   # Defensive default

    local theme_file
    theme_file="${PERSISTENT_DIR}/theme"

    if [ -f "$theme_file" ]; then
        local saved
        read -r saved < "$theme_file" 2>/dev/null || saved=""
        case "$saved" in
            default|energetic|minimal)
                THEME="$saved"
                ;;
            *)
                THEME="default"   # corrupted or invalid → safe fallback
                ;;
        esac
    else
        THEME="default"
    fi
}

# =============================================================================
# get_icon() - Returns unicode icon based on theme and context
# =============================================================================
#
# Usage:
#   icon=$(get_icon "work")
#   icon=$(get_icon "break")
#   icon=$(get_icon "done")
#
# Supported contexts: work, break, done, skip, stats, running
#
# Always returns a safe fallback (empty string) in case of error.
# Designed to be called frequently (status, watch, list, etc.).
# =============================================================================

get_icon() {
    local context="$1"

    # Defensive: ensure THEME is always valid
    case "$THEME" in
        default|energetic|minimal) ;;
        *) THEME="default" ;;
    esac

    case "$THEME,$context" in
        # Default theme - classic tomato style
        default,work)     echo "🍅" ;;
        default,break)    echo "☕" ;;
        default,done)     echo "✅" ;;
        default,skip)     echo "⏭️" ;;
        default,stats)    echo "📊" ;;
        default,running)  echo "⏳" ;;

        # Energetic theme - dynamic & motivating
        energetic,work)   echo "⚡" ;;
        energetic,break)  echo "🌿" ;;
        energetic,done)   echo "🏆" ;;
        energetic,skip)   echo "⛔" ;;
        energetic,stats)  echo "⭐" ;;
        energetic,running) echo "🔥" ;;

        # Minimal theme - zen & clean
        minimal,work)     echo "⏳" ;;
        minimal,break)    echo "🧘" ;;
        minimal,done)     echo "✨" ;;
        minimal,skip)     echo "×" ;;
        minimal,stats)    echo "·" ;;
        minimal,running)  echo "⋯" ;;

        # Safe fallback for any unknown combination
        *) echo "⏱️" ;;
    esac
}

# =============================================================================
# get_bar_filled() - Returns character used for filled part of progress bar
# =============================================================================
#
# Different themes use slightly different visual styles for the filled portion.
# Returns a single character. Always safe.
# =============================================================================

get_bar_filled() {
    case "$THEME" in
        default)   echo "█" ;;    # Full block - bold and classic
        energetic) echo "█" ;;    # Same as default for strong visual impact
        minimal)   echo "█" ;;    # Still use full block for clarity
        *)         echo "█" ;;    # Safe fallback
    esac
}

# =============================================================================
# get_bar_empty() - Returns character used for empty part of progress bar
# =============================================================================
#
# Gives each theme its distinct minimal/zen feel.
# Returns a single character. Always safe.
# =============================================================================

get_bar_empty() {
    case "$THEME" in
        default)   echo "░" ;;    # Light shade - clean and common
        energetic) echo "░" ;;    # Same as default for consistency
        minimal)   echo "□" ;;    # White square - more minimal/zen look
        *)         echo "░" ;;    # Safe fallback
    esac
}

# =============================================================================
# get_phase_color() - Returns ANSI color code for current phase
# =============================================================================
#
# Returns color based on active theme.
# Must be used inside output_text() or with proper color handling.
# Returns empty string in non-interactive / quiet / JSON mode (handled by caller).
# =============================================================================

get_phase_color() {
    # Defensive: ensure THEME is valid
    case "$THEME" in
        default|energetic|minimal) ;;
        *) THEME="default" ;;
    esac

    case "$THEME" in
        default)   echo "${GREEN}" ;;
        energetic) echo "${CYAN}" ;;
        minimal)   echo "${BLUE}" ;;
        *)         echo "${GREEN}" ;;   # Safe fallback
    esac
}

# =============================================================================
# repeat_string() - Repeat any string (including UTF-8) N times
# =============================================================================
#
# Pure POSIX implementation using only parameter expansion and a while loop.
# This is the safest way to repeat multi-byte UTF-8 characters (░ █ □ 🍅 etc.)
# across dash, ash (BusyBox), Git Bash, and standard shells.
#
# It avoids sed/awk/tr entirely, which can corrupt or fail on wide characters
# in minimal environments.
#
# Usage:
#   bar_filled=$(repeat_string "$(get_bar_filled)" 18)
#   bar_empty=$(repeat_string "$(get_bar_empty)" 12)
# =============================================================================

repeat_string() {
    local str="$1"
    local count="$2"
    local result=""

    # Defensive: treat negative or non-number as 0
    case "$count" in
        *[!0-9]*|"") count=0 ;;
    esac

    while [ "$count" -gt 0 ]; do
        result="${result}${str}"
        count=$((count - 1))
    done

    printf "%s" "$result"
}

# =============================================================================
# render_bar() - Build a progress bar string (filled + empty)
# =============================================================================
#
# This is the recommended replacement for repeat_char() when building
# themed progress bars in pomo.
#
# Why a dedicated render_bar instead of a generic repeat_char?
#   - It directly produces the full bar in one go
#   - Better performance (fewer function calls)
#   - Handles UTF-8 characters correctly on BusyBox ash / dash / Git Bash
#   - Fully POSIX compliant, no external tools beyond printf
#
# Usage:
#   bar=$(render_bar "$filled_count" "$empty_count" )
#   printf "%s%s" "$bar_filled_part" "$bar_empty_part"   # or just use the returned string
#
# Always returns something safe even if count=0 or invalid input.
# =============================================================================

render_bar() {
    local filled_count="$1"
    local empty_count="$2"
    local filled_char empty_char

    # Defensive defaults
    : "${filled_count:=0}"
    : "${empty_count:=0}"

    # Get theme-specific characters (single character, possibly UTF-8)
    filled_char=$(get_bar_filled)
    empty_char=$(get_bar_empty)

    # Build filled part
    local filled=""
    while [ "$filled_count" -gt 0 ]; do
        filled="${filled}${filled_char}"
        filled_count=$((filled_count - 1))
    done

    # Build empty part
    local empty=""
    while [ "$empty_count" -gt 0 ]; do
        empty="${empty}${empty_char}"
        empty_count=$((empty_count - 1))
    done

    # Return the complete bar
    printf "%s%s" "$filled" "$empty"
}

# =============================================================================
# show_pomo_status() - SINGLE SOURCE OF TRUTH for pomodoro status display
# =============================================================================
#
# Displays current pomodoro with:
#   - Themed icon + phase name
#   - Remaining time in MM:SS
#   - UTF-8 progress bar (using render_bar)
#   - Automatic cleanup of expired pomodoros
#
# Critical behavior:
#   - If work phase reaches 0  → automatically start break phase using saved break_dur
#   - If break phase reaches 0 → end session cleanly
#   - break_dur is ALWAYS preserved from the original start command
#
# Fully respects --quiet and --json modes.
# Uses central storage via get_app_file() + resolve_app_base_dir().
#
# !!! THIS IS THE MAIN STATUS RENDERER !!!
# Used by status, watch, and list commands.
# Do not duplicate this logic elsewhere.
# =============================================================================

show_pomo_status() {
    local name="${1:-default}"
    local mode="${2:-volatile}"
    local APP_FILE
    APP_FILE=$(get_app_file "$name" "$mode")

    if [ ! -f "$APP_FILE" ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "No pomodoro '${name}' running." "no_pomodoro"
        else
            if [ "${QUIET}" -eq 0 ]; then
                warn "No pomodoro '${name}' running."
            fi
        fi
        return 1
    fi

    # Read full state - both durations must be present
    local start_time target_time phase work_dur break_dur
    if ! read -r start_time target_time phase work_dur break_dur < "$APP_FILE" 2>/dev/null; then
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Corrupted pomodoro file for '${name}'" "corrupted_data"
        else
            error "Corrupted pomodoro file."
        fi
        rm -f "$APP_FILE" 2>/dev/null || true
        return 1
    fi

    # Defensive: ensure durations are valid numbers
    work_dur=${work_dur:-300}
    break_dur=${break_dur:-300}

    local current_time remaining
    current_time=$(date +%s 2>/dev/null) || current_time=0
    remaining=$((target_time - current_time))

    # ==================== EXPIRATION + TRANSITION LOGIC ====================
    if [ "$remaining" -le 0 ]; then

        if [ "$phase" = "work" ]; then
            # === WORK JUST ENDED → START BREAK ===
            local new_start new_target
            new_start=$(date +%s)
            new_target=$((new_start + break_dur))

            # Write break phase - preserve both original durations
            if ! printf "%s %s %s %s %s\n" \
                "$new_start" "$new_target" "break" "$work_dur" "$break_dur" \
                > "$APP_FILE" 2>/dev/null; then
                if [ "${JSON}" -eq 1 ]; then
                    output_json_error "Failed to start break phase" "io_error"
                else
                    error "Failed to start break phase."
                fi
                return 1
            fi

            # Show break immediately
            if [ "${JSON}" -eq 1 ]; then
                output_json "status" "" \
                    "name" "$name" \
                    "mode" "$mode" \
                    "phase" "break" \
                    "phase_name" "Break" \
                    "duration" "$break_dur" \
                    "remaining" "$break_dur" \
                    "minutes" "$((break_dur / 60))" \
                    "seconds" "$((break_dur % 60))" \
                    "percent" "0"
            else
                if [ "${QUIET}" -eq 0 ]; then
                    local icon color
                    icon=$(get_icon "break")
                    color=$(get_phase_color)
                    printf '\a'
                    printf "\n${color}%s Break phase started${NC} — %d minutes\n\n" \
                        "$icon" "$((break_dur / 60))"
                fi
            fi
            return 0
        fi

        # === BREAK JUST ENDED → SESSION COMPLETE ===
        rm -f "$APP_FILE" 2>/dev/null || true
        if [ "${JSON}" -eq 1 ]; then
            output_json "status" "" \
                "name" "$name" \
                "mode" "$mode" \
                "phase" "break" \
                "remaining" "0" \
                "expired" "true"
        else
            if [ "${QUIET}" -eq 0 ]; then
                local icon
                icon=$(get_icon "done")
                success "${icon} Pomodoro session completed!"
                printf '\a'
            fi
        fi
        return 2   # Signal to watch mode that full session is done
    fi

    # ==================== STILL RUNNING ====================
    local total_seconds=$((target_time - start_time))
    [ "$total_seconds" -le 0 ] && total_seconds=1
    local percent=$(( (total_seconds - remaining) * 100 / total_seconds ))
    [ "$percent" -gt 100 ] && percent=100
    [ "$percent" -lt 0 ] && percent=0

    local minutes=$((remaining / 60))
    local seconds=$((remaining % 60))

    local phase_name="Pomodoro"
    [ "$phase" = "work" ] && phase_name="Work"
    [ "$phase" = "break" ] && phase_name="Break"

    local icon color
    icon=$(get_icon "$phase")
    color=$(get_phase_color)

    if [ "${JSON}" -eq 1 ]; then
        output_json "status" "" \
            "name" "$name" \
            "mode" "$mode" \
            "phase" "$phase" \
            "phase_name" "$phase_name" \
            "duration" "$total_seconds" \
            "remaining" "$remaining" \
            "minutes" "$minutes" \
            "seconds" "$seconds" \
            "percent" "$percent"
        return 0
    fi

    if [ "${QUIET}" -eq 1 ]; then
        return 0
    fi

    local bar_width=30
    local filled_count=$(( (percent * bar_width + 50) / 100 ))
    local empty_count=$((bar_width - filled_count))
    local bar
    bar=$(render_bar "$filled_count" "$empty_count")

    printf "\n${color}%s %s${NC}   %02d:%02d remaining\n" \
        "$icon" "$phase_name" "$minutes" "$seconds"

    printf "  %s  %3d%%\n" "$bar" "$percent"

    if [ "$mode" = "persistent" ]; then
        printf "  (persistent mode)\n"
    fi
    printf "\n"

    return 0
}

