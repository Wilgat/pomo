#!/bin/sh

# pomo — Simple & Beautiful Pomodoro Timer 🌿
# Version: 1.3.7 (MIT License)
# GitHub: https://github.com/Wilgat/pomo
#
# Why? Dead-simple Pomodoro (25min work + 5min break) with themes, stats, watch.
# No deps. Portable. Unicode-safe.
#
# Usage examples:
#   pomo start [minutes] [--break N] [--persist]
#   pomo status
#   pomo watch
#   pomo skip / stop / stats / theme set energetic
#
# Install (pick one):
#   curl -fsSL https://raw.githubusercontent.com/Wilgat/pomo/main/pomo | sh
#   sudo curl -fsSL https://raw.githubusercontent.com/Wilgat/pomo/main/pomo | sudo sh

# ─────── Colors (TTY-safe) ──────────────────────────────────────────────────────
if [ -t 1 ]; then
    RED='\033[0;31m' GREEN='\033[0;32m' YELLOW='\033[1;33m'
    BLUE='\033[0;34m' CYAN='\033[0;36m' NC='\033[0m'
else
    RED='' GREEN='' YELLOW='' BLUE='' CYAN='' NC=''
fi

# ─────── Constants ───────────────────────────────────────────────────────────────
APP_NAME="pomo"
APP_VER="1.3.7"
REPO_BASE_URL="https://raw.githubusercontent.com/Wilgat/pomo/main"
SCRIPT_URL="${REPO_BASE_URL}/${APP_NAME}"
GLOBAL_BIN="/usr/local/bin"
USER_BIN="${HOME}/.local/bin"

USERNAME="$(id -un 2>/dev/null || echo unknown)"
VOLATILE_DIR="/tmp"  # Portable /dev/shm replacement (clears less often, but timers short)
PERSISTENT_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/pomo"
THEME_FILE="${PERSISTENT_DIR}/theme"

DEFAULT_WORK=1500  # 25min
DEFAULT_BREAK=300  # 5min

# Dynamic
IS_ROOT=0
INSTALL_DIR=""
INSTALL_PATH=""
PERSIST=false
FORCE=false
COMMAND=""
WORK_MIN=""
BREAK_MIN=""
STORAGE_MODE="volatile"
THEME="default"
should_install=""

# ─────── Setup ───────────────────────────────────────────────────────────────────
detect_install_locations() {
    mkdir -p "$VOLATILE_DIR" "$PERSISTENT_DIR" || {
        printf "${RED}Error: Failed mkdir %s or %s${NC}\n" "$VOLATILE_DIR" "$PERSISTENT_DIR" >&2
        exit 1
    }
    if [ "$(id -u)" -eq 0 ]; then
        IS_ROOT=1
        INSTALL_DIR="$GLOBAL_BIN"
    else
        IS_ROOT=0
        INSTALL_DIR="$USER_BIN"
    fi
    INSTALL_PATH="${INSTALL_DIR}/${APP_NAME}"
}
detect_install_locations

# ─────── Core utils ──────────────────────────────────────────────────────────────
reload_theme() {
    if [ -f "$THEME_FILE" ]; then
        read -r THEME < "$THEME_FILE" 2>/dev/null || THEME="default"
        case "$THEME" in default|energetic|minimal) ;; *) THEME="default" ;; esac
    fi
}

get_icon() {
    local tmp_theme="${2:-$THEME}"
    case "$tmp_theme,$1" in
        default,work) echo "🍅" ;; default,break) echo "☕" ;;
        default,done) echo "✅" ;; default,skip) echo "⏭️" ;;
        default,stats) echo "📊" ;; default,running) echo "⏳" ;;
        energetic,work) echo "⚡" ;; energetic,break) echo "🌿" ;;
        energetic,done) echo "🏆" ;; energetic,skip) echo "⛔" ;;
        energetic,stats) echo "⭐" ;; energetic,running) echo "🔥" ;;
        minimal,work) echo "⏳" ;; minimal,break) echo "🧘" ;;
        minimal,done) echo "✨" ;; minimal,skip) echo "×" ;;
        minimal,stats) echo "·" ;; minimal,running) echo "⋯" ;;
        *) echo "" ;;
    esac
}

get_bar_filled() { echo "█"; }
get_bar_empty() {
    case "$THEME" in minimal) echo "□" ;; *) echo "░" ;; esac
}
get_phase_color() {
    case "$THEME" in default) echo "$GREEN" ;; energetic) echo "$CYAN" ;; minimal) echo "$BLUE" ;; *) echo "$GREEN" ;; esac
}

repeat_char() {
    printf '%*s' "$2" '' | tr ' ' "$1"
}

get_pomo_file() {
    local name="$1" mode="${2:-$STORAGE_MODE}"
    local dir; [ "$mode" = "persistent" ] && dir="$PERSISTENT_DIR" || dir="$VOLATILE_DIR"
    printf '%s/pomo_%s_%s' "$dir" "$USERNAME" "$name"
}

get_today() { date +%Y-%m-%d 2>/dev/null || echo "1970-01-01"; }
get_stats_file() { printf '%s/stats_%s' "$PERSISTENT_DIR" "$(get_today)"; }

die() {
    printf "${RED}Error: %s${NC}\n" "$*" >&2
    exit 1
}

is_installed() {
    if [ "$IS_ROOT" -eq 1 ]; then
        [ -f "${GLOBAL_BIN}/${APP_NAME}" ] && [ -x "${GLOBAL_BIN}/${APP_NAME}" ]
    else
        { [ -f "${GLOBAL_BIN}/${APP_NAME}" ] && [ -x "${GLOBAL_BIN}/${APP_NAME}" ]; } ||
        { [ -f "${USER_BIN}/${APP_NAME}"   ] && [ -x "${USER_BIN}/${APP_NAME}"   ]; }
    fi
}

in_path() {
    printf '%s\n' "$PATH" | grep -qF "$INSTALL_DIR"
}

add_to_bashrc() {
    local rc="${HOME}/.bashrc"
    if ! grep -qF 'export PATH="${HOME}/.local/bin:$PATH"' "$rc" 2>/dev/null; then
        {
            printf '\n# Added by %s %s\n' "$APP_NAME" "$APP_VER"
            printf 'export PATH="${HOME}/.local/bin:$PATH"\n'
        } >> "$rc"
        printf "${GREEN}✓ Added ~/.local/bin to ~/.bashrc${NC}\n"
    fi
}

show_help() {
    cat << EOF
${YELLOW}pomo${NC} ${APP_VER} — Simple & Beautiful Pomodoro Timer

Usage:
  pomo start [minutes] [--break N] [--persist]
  pomo status / watch / skip / stop [--force] / kill
  pomo list [--persist] / stats
  pomo theme [list / set <name> / next / prev]
  pomo version / help

Themes: default • energetic • minimal
Examples:
  pomo start 25 --break 10
  pomo watch  # Live status (Ctrl+C exit)
EOF
}

perform_self_install() {
    mkdir -p "$INSTALL_DIR" || die "mkdir $INSTALL_DIR"
    local temp_file="/tmp/${USER:-nobody}-${APP_NAME}-$$"
    curl -fsSL "$SCRIPT_URL" -o "$temp_file" || { rm -f "$temp_file"; die "curl failed"; }
    chmod +x "$temp_file" || { rm -f "$temp_file"; die "chmod failed"; }
    mv "$temp_file" "$INSTALL_PATH" || { rm -f "$temp_file"; die "mv to $INSTALL_PATH"; }
    rm -f "$temp_file"
    printf "${GREEN}✓ Installed to %s${NC}\n" "$INSTALL_PATH"
}

maybe_install() {
    if is_installed; then return 0; fi
    reload_theme  # Early for icons

    printf "\n${YELLOW}Note: '%s' is not installed yet${NC}\n" "$APP_NAME" 
    printf "     Recommended command:\n\n" 

    if [ "$IS_ROOT" -eq 1 ]; then
        printf "     ${GREEN}sudo curl -fsSL %s | sudo sh${NC}\n" "$SCRIPT_URL" 
    else
        printf "     ${GREEN}curl -fsSL %s | sh${NC}\n" "$SCRIPT_URL" 
    fi
    printf "\n" 

    should_install=false

    if [ -t 0 ] && [ -t 1 ]; then
        # Interactive
        printf "     Install now? (y/N): " 
        read -r answer </dev/tty 2>/dev/null || read -r answer 
        case "$answer" in [yY]*) should_install=true ;; esac 
    else
        # Non-interactive (curl|sh): auto-yes
        should_install=true 
    fi

    if [ "$should_install" = true ]; then
        printf "${YELLOW}Installing...${NC}\n" 
        perform_self_install || exit 1
        if [ "$IS_ROOT" -eq 0 ] && ! in_path; then
            add_to_bashrc
            printf "\n${YELLOW}Important:${NC} ~/.local/bin was not in your PATH.\n"
            printf "          We added it to ~/.bashrc.\n"
            printf "\n"
            printf "          Please run one of these commands now:\n"
            printf "            ${GREEN}. ~/.bashrc${NC}\n"
            printf "          or\n"
            printf "            ${GREEN}source ~/.bashrc${NC}\n"
            printf "\n"
            printf "          After that, you can use ${GREEN}%s${NC}.\n" "$APP_NAME"
        else
            printf "You can now run ${GREEN}%s${NC}.\n" "$APP_NAME"
        fi
    fi
}

is_active() {
    [ -f "$(get_pomo_file work)" ] || [ -f "$(get_pomo_file break)" ]
}

cmd_start() {
    local wf="$(get_pomo_file work)"
    [ -f "$wf" ] && { printf "${YELLOW}Work already active.${NC}\n"; return 1; }
    WORK_MIN="${1:-25}"
    [ "$WORK_MIN" -eq "$WORK_MIN" ] 2>/dev/null || WORK_MIN=25
    local ws="$((WORK_MIN * 60))"
    BREAK_MIN="${BREAK_MIN:-5}"
    [ "$BREAK_MIN" -eq "$BREAK_MIN" ] 2>/dev/null || BREAK_MIN=5
    local bs="$((BREAK_MIN * 60))"
    date +%s > "$wf" || die "start timer"
    printf "${GREEN}%s Pomodoro started (%s min work + %s min break)${NC}\n" \
        "$(get_icon work)" "$WORK_MIN" "$BREAK_MIN"
    [ "$PERSIST" = true ] && printf "  (persistent)\n"
    # Background cycle
    ( sleep "$ws" && {
        printf '\a'; printf "\n${GREEN}%s Work done! %s Break.${NC}\n" "$(get_icon done)" "$(get_icon break)"
        rm -f "$wf"; date +%s > "$(get_pomo_file break)"; sleep "$bs" && {
            printf '\a'; printf "${GREEN}%s Break over!${NC}\n" "$(get_icon done)"; rm -f "$(get_pomo_file break)"
        }
    } ) >/dev/null 2>&1 &
}

cmd_status() {
    reload_theme
    local wf="$(get_pomo_file work)" bf="$(get_pomo_file break)"
    local file phase total icon c
    if [ -f "$wf" ]; then file="$wf"; phase="Work"; total="$DEFAULT_WORK"; icon="$(get_icon work)"; c="$(get_phase_color)"
    elif [ -f "$bf" ]; then file="$bf"; phase="Break"; total="$DEFAULT_BREAK"; icon="$(get_icon break)"; c="$(get_phase_color)"
    else printf "${YELLOW}No active pomodoro.${NC}\n"; return 0; fi
    local s="$(cat "$file")" n="$(date +%s)" e="$((n - s))" r="$((total - e))"
    [ "$r" -lt 0 ] && r=0
    local p="$((e * 100 / total))"; [ "$p" -gt 100 ] && p=100
    local w=30 f="$(((e * w + total / 2) / total))"; [ "$f" -gt "$w" ] && f="$w"
    local bar="$(repeat_char "$(get_bar_filled)" "$f")"
    local emp="$(repeat_char "$(get_bar_empty)" "$((w - f))")"
    printf "\n${c}%s %s${NC}  %02d:%02d left\n" "$icon" "$phase" "$((r/60))" "$((r%60))"
    printf "  %s%s  %3d%%\n\n" "$bar" "$emp" "$p"
    [ "$PERSIST" = true ] && echo "  (persistent)"
}

cmd_watch() {
    cmd_start "$@"
    printf "${YELLOW}Watching... (Ctrl+C exit)${NC}\n\n"
    while is_active; do
        clear 2>/dev/null || tput clear 2>/dev/null || printf '\033[2J\033[H'
        cmd_status
        printf "\r${CYAN}↻ %s | theme: %s${NC}   " "$(date +%H:%M:%S)" "$THEME"
        sleep 1
    done
}

cmd_skip() {
    rm -f "$(get_pomo_file work)" "$(get_pomo_file break)"
    printf "${YELLOW}%s Skipped.${NC}\n" "$(get_icon skip)"
}

cmd_stop() {
    local wf="$(get_pomo_file work)"
    [ -f "$wf" ] || { printf "${YELLOW}No work pomodoro.${NC}\n"; return 1; }
    local s="$(cat "$wf")" n="$(date +%s)" e="$((n - s))" m="$((e / 60))"
    rm -f "$wf"
    if [ "$FORCE" = true ] || [ "$COMMAND" = "kill" ]; then
        printf "${YELLOW}%s Discarded.${NC}\n" "$(get_icon skip)"; return 0
    fi
    local sf="$(get_stats_file)" p=0 t=0
    [ -f "$sf" ] && read p t < "$sf"
    p="$((p + 1))" t="$((t + m))"
    printf '%s %s\n' "$p" "$t" > "$sf"
    printf "${GREEN}%s Completed %s min${NC}\n" "$(get_icon done)" "$m"
    printf "Today: %s pomodoros • %s min\n" "$p" "$t"
}

cmd_list() {
    printf "Pomodoros (%s):\n" "$STORAGE_MODE"
    local f=0
    for dir in "$VOLATILE_DIR" "$PERSISTENT_DIR"; do
        for file in "$dir"/pomo_"${USERNAME}"_*; do
            [ -f "$file" ] || continue
            f=1
            local name="${file##*pomo_${USERNAME}_}" s="$(cat "$file")" now="$(date +%s)" elapsed="$((now - s))"
            printf "  %s %-18s %02d:%02d\n" "$(get_icon running)" "$name" "$((elapsed/60))" "$((elapsed%60))"
        done
    done
    [ "$f" -eq 0 ] && printf "  (none)\n"
}

cmd_stats() {
    local sf="$(get_stats_file)"
    if [ -f "$sf" ]; then
        local p t; read p t < "$sf"
        printf "${GREEN}Today:${NC} %s pomodoros • %s min\n" "$p" "$t"
    else
        printf "No stats today.\n"
    fi
}

cmd_theme() {
    local sub="$1" arg="$2"
    [ -z "$sub" ] && die "theme <list|set name|next|prev>"
    case "$sub" in
        list)
            printf "Themes:\n  default   $(get_icon work default)$(get_icon break default)$(get_icon done default)\n"
            printf "  energetic $(get_icon work energetic)$(get_icon break energetic)$(get_icon done energetic)\n"
            printf "  minimal   $(get_icon work minimal)$(get_icon break minimal)$(get_icon done minimal)\n"
            printf "Current: ${GREEN}%s${NC}\n" "$THEME"
            ;;
        set)
            case "${arg:-}" in default|energetic|minimal)
                printf '%s\n' "$arg" > "$THEME_FILE"
                THEME="$arg"
                printf "Theme: ${GREEN}%s %s${NC}\n" "$THEME" "$(get_icon work)"
                ;;
            *) die "Invalid: default/energetic/minimal" ;;
            esac
            ;;
        next) local new; case "$THEME" in default) new=energetic;; energetic) new=minimal;; *) new=default;; esac; printf '%s\n' "$new" > "$THEME_FILE"; THEME="$new"; printf "Next: ${GREEN}%s${NC}\n" "$THEME" ;;
        prev) local new; case "$THEME" in default) new=minimal;; minimal) new=energetic;; *) new=default;; esac; printf '%s\n' "$new" > "$THEME_FILE"; THEME="$new"; printf "Prev: ${GREEN}%s${NC}\n" "$THEME" ;;
        *) die "Unknown: list/set/next/prev" ;;
    esac
}

cmd_version() { printf "%s %s\n" "$APP_NAME" "$APP_VER"; }
cmd_help() { show_help; }

# ─────── Parse & dispatch ─────────────────────────────────────────────────────────
parse_args() {
    while [ $# -gt 0 ]; do
        case "$1" in
            --persist) PERSIST=true; shift ;;
            --force) FORCE=true; shift ;;
            --break) BREAK_MIN="$2"; shift 2 || die "--break <N>" ;;
            start|status|skip|stop|kill|list|stats|watch|theme|version|help)
                COMMAND="$1"; shift; break ;;
            *) die "Unknown: $1 (pomo help)" ;;
        esac
    done
    STORAGE_MODE="$([ "$PERSIST" = true ] && echo persistent || echo volatile)"
    case "$COMMAND" in
        start|watch) WORK_MIN="$1" ;;  # Positional minutes for start/watch
        theme) cmd_theme "$1" "$2" ;;
        version) cmd_version ;;
        help) cmd_help ;;
        status) cmd_status ;;
        skip) cmd_skip ;;
        stop|kill) cmd_stop ;;
        list) cmd_list ;;
        stats) cmd_stats ;;
    esac
}

run_command() {
    case "$COMMAND" in
        start) cmd_start "$1" "$@" ;;  # Pass args
        watch) cmd_watch "$1" "$@" ;;
        *) ;;  # Handled above
    esac
}

main() {
    reload_theme
    parse_args "$@"
    if [ -z "$COMMAND" ]; then maybe_install; cmd_help; exit 0; fi
    maybe_install
    run_command "$@"
}

main "$@"