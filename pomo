# ----------------------------- Date Helpers ----------------------------------
# Returns current date in YYYY-MM-DD format (used for daily stats)
get_today() {
    date +%Y-%m-%d 2>/dev/null || echo "1970-01-01"
}

# ----------------------------- Stats File Path -------------------------------
# Returns full path to today's stats file using central storage resolver
get_stats_file() {
    local base_dir
    base_dir=$(resolve_app_base_dir "persistent")   # Always use persistent for stats

    echo "${base_dir}/stats_$(get_today)"
}

# =============================================================================
# main_pomo() - Main dispatcher for the pomo tool
# =============================================================================
#
# Handles argument parsing and routes to the correct pomo functions.
# Improved start command parsing to correctly handle name vs duration.
#
# Supported start syntax:
#   pomo start
#   pomo start 40
#   pomo start focus 40
#   pomo start 50 --break 10 --persist
#   pomo start work 25 --break 5
#
# IMPORTANT DESIGN DECISION:
#   The auto-install logic (`maybe_install` / `perform_self_install`) is triggered
#   when the script is run with ZERO arguments via `curl | sh`.
#
#   This is INTENTIONAL and CRITICAL for the one-liner installer to work.
#   Without it, `curl -fsSL ... | sh` would only print help and exit, leaving
#   the user with "command not found" — exactly the problem we are solving.
#
#   Even though subcommands like "help", "version", or "about" exist,
#   we still want to check/install first in the curl | sh context because
#   the primary use-case of piping the raw script is installation.
#
#   This pattern is common in robust single-file CLI tools and must be preserved.
#
# !!! DO NOT REMOVE OR SIMPLIFY THE AUTO-INSTALL BLOCK !!!
#   Many AI assistants will try to "clean it up", move it after parsing,
#   or tie it only to specific subcommands.
#   Doing so would break the one-liner installation experience (`curl | sh`),
#   which is one of the core promises of this project.
#
#   Previous Grok versions already attempted to remove or relocate this logic.
#   Respect this decision and keep the auto-install check at the top, before
#   any argument parsing.
# =============================================================================

main_pomo() {
    # ---------------------- Default Variables ----------------------
    local COMMAND="help"
    NAME="default"
    PERSIST=0
    FORCE=0
    CUSTOM_WORK=""
    CUSTOM_BREAK=""

    # === AUTO-INSTALL FOR ONE-LINER (curl | sh) ===
    # This block MUST stay at the very top
    if ! is_installed && [ $# -eq 0 ]; then
        if [ "${JSON}" -eq 1 ] || [ "${QUIET}" -eq 1 ]; then
            perform_self_install
        else
            maybe_install
        fi
        exit 0
    fi

    # === IMPROVED ARGUMENT PARSING - Flags first ===
    while [ $# -gt 0 ]; do
        case "$1" in
            --persist)
                PERSIST=1
                ;;
            --force)
                FORCE=1
                ;;
            --quiet|-q)
                QUIET=1
                ;;
            --json)
                JSON=1
                QUIET=1
                ;;
            --break)
                if [ -z "$2" ] || ! printf '%s' "$2" | grep -qE '^[0-9]+$'; then
                    if [ "${JSON}" -eq 1 ]; then
                        output_json_error "--break requires a positive number" "invalid_argument"
                    else
                        error "--break requires a positive number (minutes)."
                    fi
                    exit 1
                fi
                CUSTOM_BREAK="$2"
                shift
                ;;
            start|status|watch|skip|stop|kill|list|stats|theme|version|help|about)
                COMMAND="$1"
                ;;
            version-check|self-update|self-uninstall)
                COMMAND="${1#--}"
                ;;
            *)
                # Positional arguments
                if [ "$COMMAND" = "start" ]; then
                    if [ -z "$CUSTOM_WORK" ] && printf '%s' "$1" | grep -qE '^[0-9]+$'; then
                        CUSTOM_WORK="$1"
                    elif [ "$NAME" = "default" ]; then
                        NAME="$1"
                    else
                        if [ "${JSON}" -eq 1 ]; then
                            output_json_error "Too many arguments" "bad_argument"
                        else
                            error "Too many arguments for start command."
                        fi
                        exit 1
                    fi
                elif [ "$COMMAND" = "theme" ]; then
                    THEME_SUBCOMMAND="$1"
                    shift
                    THEME_ARG="$1"
                    break
                else
                    NAME="$1"
                fi
                ;;
        esac
        shift
    done

    # === Validation for start command ===
    if [ "$COMMAND" = "start" ] && [ -n "$CUSTOM_WORK" ] && [ "$CUSTOM_WORK" -le 0 ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Work duration must be positive" "invalid_duration"
        else
            error "Work duration must be positive."
        fi
        exit 1
    fi

    # Sanitize name when needed
    if [ "$COMMAND" = "start" ] || [ "$COMMAND" = "status" ] || [ "$COMMAND" = "stop" ] || \
       [ "$COMMAND" = "kill" ] || [ "$COMMAND" = "skip" ] || [ "$COMMAND" = "watch" ] || \
       [ "$COMMAND" = "list" ]; then
        sanitize_name
    fi

    # Determine storage mode
    local STORAGE_MODE
    STORAGE_MODE=$([ "$PERSIST" -eq 1 ] && echo "persistent" || echo "volatile")

    # Load theme early
    load_theme

    # === Command Dispatch ===
    case "$COMMAND" in
        start)
            pomo_start "$CUSTOM_WORK"
            ;;

        status)
            show_pomo_status "$NAME" "$STORAGE_MODE"
            ;;

        watch)
            pomo_watch "$NAME" "$STORAGE_MODE"
            ;;

        skip)
            pomo_skip "$NAME" "$STORAGE_MODE"
            ;;

        stop)
            pomo_stop "$NAME" "$STORAGE_MODE"
            ;;

        kill)
            FORCE=1
            pomo_stop "$NAME" "$STORAGE_MODE"
            ;;

        list)
            pomo_list "$STORAGE_MODE"
            ;;

        stats)
            pomo_stats
            ;;

        theme)
            pomo_theme "$THEME_SUBCOMMAND" "$THEME_ARG"
            ;;

        version)
            if [ "${JSON}" -eq 1 ]; then
                output_json "version" "" "app" "${APP_NAME}" "version" "${VERSION}"
            else
                msg "${APP_NAME} version ${VERSION}"
            fi
            ;;

        about)
            show_about
            ;;

        version-check)
            version_check
            ;;

        self-update)
            self_update
            ;;

        self-uninstall)
            self_uninstall
            ;;

        help|*)
            show_pomo_help
            ;;
    esac
}

# Call the main function
main_pomo "$@"